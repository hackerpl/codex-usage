{
  "name": "codex-usage",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "node -e \"const fs=require('fs');['dist','node_modules/.vite','src-tauri/target'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\"",
