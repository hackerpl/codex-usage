{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Usage",
  "version": "0.1.0",
  "identifier": "com.blackird.codex-usage",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Usage",
        "width": 430,
        "height": 780,
        "minWidth": 430,
        "minHeight": 720,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
